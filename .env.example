# Copy to .env.local and fill in. Never commit real keys to .env.example.

# Spotify Web API — Client Credentials flow
# https://developer.spotify.com/documentation/web-api/concepts/client-credentials
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# OpenAI — analysis
OPENAI_API_KEY=

# Lyrics — Musixmatch is preferred (commercial-friendly). Genius is the dev
# fallback when MUSIXMATCH_KEY is unset.
# https://developer.musixmatch.com (free tier returns 30% snippet only)
MUSIXMATCH_KEY=
# https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=
# Postgres — analysis cache. Optional in dev; cache silently no-ops when unset.
# Supabase connection string works directly.
DATABASE_URL=

# Clerk — auth + saved library
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Upstash Redis — rate limiting + 24h Spotify metadata cache.
# Optional; both features no-op gracefully when unset.
# https://upstash.com/docs/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: override the auto-detected canonical URL used for OG / sitemap.
# Vercel populates VERCEL_URL automatically.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
